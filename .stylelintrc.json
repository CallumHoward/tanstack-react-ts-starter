{
  "extends": ["stylelint-config-standard"],
  "ignoreFiles": ["dist/**", ".output/**", "node_modules/**"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "apply",
          "custom-variant",
          "variant",
          "utility",
          "source",
          "plugin",
          "reference",
          "config",
          "tailwind",
          "screen",
          "responsive"
        ]
      }
    ]
  }
}
